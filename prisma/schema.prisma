// Mediation Helper — data model
// Prisma 7 + PostgreSQL (Neon). The datasource URL comes from prisma.config.ts (DATABASE_URL in .env).
// Status/role/value-state fields are Strings with allowed values documented inline.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A signed-in person, synced from Clerk on first access.
model User {
  id          String   @id // Clerk user id
  email       String?
  displayName String
  createdAt   DateTime @default(now())

  parties           Party[]
  ownedNegotiations Negotiation[]
  aiUsage           AiUsage[]
}

/// A negotiation/case.
model Negotiation {
  id           String    @id @default(cuid())
  label        String
  description  String    @default("") // <= 200 words
  deadlineDate DateTime?
  deadlineTime String? // optional "HH:MM"
  status       String    @default("In Progress") // In Progress | Resolved | Abandoned | Ended
  ownerUserId  String
  owner        User      @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  inviteCode   String    @unique @default(cuid())
  scipab       String? // JSON of the AI-drafted SCIPAB "document of record" (the agreement)
  scipabAt     DateTime? // when the SCIPAB was last drafted
  // --- Closure (set by the Guide via "End negotiation"): outcome + exit survey ---
  endedAt        DateTime?
  resolutionType String? // the picklist outcome the Guide selected
  fbHelped       String? // Likert: "This app helped me run a better negotiation"
  fbFavorite     String? // free text: favorite thing
  fbChange       String? // free text: one thing to change
  fbOther        String? // free text: anything else for Xander
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  parties      Party[]
  interests    Interest[]
  options      Option[]
  chatMessages ChatMessage[]
  aiCalls      AiCall[]
  auditLogs    AuditLog[]
}

/// A stakeholder seat in a workspace. Created by the owner (PM); may be a proxy seat
/// (userId null) until a real person claims it via the party's own invite link.
model Party {
  id             String   @id @default(cuid())
  negotiationId  String
  negotiation    Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  userId         String? // null = proxy seat not yet claimed by a real user
  user           User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  inviteCode     String   @unique @default(cuid()) // per-party invite link token
  pointBudget    Int      @default(10) // interest points this party may spend (nudger-configurable)
  displayName    String
  about          String   @default("") // <= 500-word general intake summary (not interests)
  role           String   @default("participant") // owner | participant
  orderIndex     Int      @default(0)
  intakeComplete Boolean  @default(false)
  interestsReady Boolean  @default(false) // party has shared their interests; gates the shared steps (priorities, scoring)
  createdAt      DateTime @default(now())

  interests      Interest[] // interests this party owns
  interestPoints InterestPoint[]
  scores         Score[]
  votes          Vote[]
  intakeMessages IntakeMessage[]
  chatMessages   ChatMessage[]

  @@unique([negotiationId, userId])
}

/// Per-[workspace × party] change log: who changed what on a party's behalf. Powers the
/// transparency/trust story so a party can see exactly what was entered for them and by whom.
model AuditLog {
  id            String   @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  partyId       String // the subject party the change is about
  actorUserId   String? // who made the change (not FK-constrained, for retention)
  actorLabel    String // display name of the actor at the time
  isProxy       Boolean  @default(false) // true = owner acting on another party's behalf
  action        String // e.g. interest.create | points.save | score.set
  detail        String? // short human-readable summary
  createdAt     DateTime @default(now())

  @@index([negotiationId, partyId])
}

/// Something a party cares about, framed positively (3-5 per party).
model Interest {
  id            String   @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  ownerPartyId  String
  ownerParty    Party    @relation(fields: [ownerPartyId], references: [id], onDelete: Cascade)
  text          String // <= 200 words
  maslowTier    String? // L1 (must-have) | L2 | null
  changed       Boolean  @default(false) // signifier when edited after scoring began
  shared        Boolean  @default(false) // true after a merge: belongs to all parties, not just the owner
  mustHave      Boolean  @default(false) // non-negotiable: highest priority class, excluded from the points allocation
  createdAt     DateTime @default(now())

  points InterestPoint[]
  scores Score[]
}

/// Interest Points a party allocates (10 total per party). Post-intake any party may
/// point any interest; during intake a party points only their own.
model InterestPoint {
  id         String   @id @default(cuid())
  interestId String
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)
  partyId    String
  party      Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  points     Int      @default(0) // 1..10

  @@unique([interestId, partyId])
}

/// A candidate solution. Authorship (source/which party) is never exposed in the UI.
model Option {
  id            String   @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  shortName     String // <= 100 chars, shown on the map
  description   String   @default("") // <= 1000 words
  source        String   @default("party") // party | mediator (internal only)
  hidden        Boolean  @default(false) // legacy — superseded by goState; no longer used
  goState       String? // null = undecided | "go" | "no_go". Per-option (shared, last-writer-wins); "no_go" auto-hides it.
  changed       Boolean  @default(false) // signifier when edited after scoring began
  createdAt     DateTime @default(now())

  scores Score[]
  votes  Vote[]
}

/// How a party scores one option against one interest.
model Score {
  id         String   @id @default(cuid())
  optionId   String
  option     Option   @relation(fields: [optionId], references: [id], onDelete: Cascade)
  interestId String
  interest   Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)
  partyId    String
  party      Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  value      Int? // 0 | 25 | 50 | 75 | 100 ; null = blank / no opinion
  na         Boolean  @default(false) // true = not applicable

  @@unique([optionId, interestId, partyId])
}

/// Non-binding per-party viability vote on an option (changeable anytime).
model Vote {
  id       String @id @default(cuid())
  optionId String
  option   Option @relation(fields: [optionId], references: [id], onDelete: Cascade)
  partyId  String
  party    Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
  value    String // go | no_go

  @@unique([optionId, partyId])
}

/// Private per-party conversation with the AI Mediator (general intake + interest elicitation).
model IntakeMessage {
  id        String   @id @default(cuid())
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id], onDelete: Cascade)
  role      String // user | assistant
  content   String
  imageType String? // media type of an attached image, e.g. "image/jpeg"
  imageData String? // base64 (no data: prefix) of an attached image
  createdAt DateTime @default(now())
}

/// Shared chat on the Negotiation Map (partyId null = AI Mediator).
model ChatMessage {
  id            String   @id @default(cuid())
  negotiationId String
  negotiation   Negotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  partyId       String?
  party         Party?   @relation(fields: [partyId], references: [id], onDelete: SetNull)
  content       String
  createdAt     DateTime @default(now())
}

/// Per-user monthly AI usage counter (cost guardrail).
model AiUsage {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  period String // "YYYY-MM" (UTC)
  count  Int    @default(0)

  @@unique([userId, period])
}

/// Pilot allowlist — emails admitted to CREATE negotiations. Anyone may still
/// JOIN via an invite link. Admins (ADMIN_EMAILS) are implicitly admitted.
/// Per-pilot-user caps are enforced on the negotiations they own.
model Allowlist {
  id           String   @id @default(cuid())
  email        String   @unique
  note         String?
  addedBy      String? // admin User id who admitted them
  maxParties   Int      @default(5) // max parties per negotiation they own
  maxOptions   Int      @default(7) // max ideas per negotiation (total across all parties)
  maxInterests Int      @default(7) // max interests per negotiation (total across all parties)
  createdAt    DateTime @default(now())
}

/// Per-call AI cost ledger powering the operator usage/cost console.
model AiCall {
  id            String       @id @default(cuid())
  negotiationId String?
  negotiation   Negotiation? @relation(fields: [negotiationId], references: [id], onDelete: SetNull)
  userId        String? // who triggered the call (not FK-constrained, for retention)
  kind          String // intake | suggest_interests | classify | suggest_options | scipab
  model         String
  inputTokens   Int          @default(0)
  outputTokens  Int          @default(0)
  costUsd       Float        @default(0)
  createdAt     DateTime     @default(now())

  @@index([negotiationId])
  @@index([createdAt])
}
